@{
    // WebMatrix @{} code block at the top
    var title = "About Mamba Framework";
    var version = "1.0.0";
    var buildDate = "2026-07-13";
    var frameworkName = "Mamba Framework";
    var description = "A production-ready Go web framework for enterprise business applications";
    
    // Features list
    var features = new List<string> {
        "WebMatrix-style syntax with @{} code blocks",
        "Layout engine with master pages (@RenderBody, @RenderSection)",
        "Database helpers (@Database.Query, @Database.Execute)",
        "Form handling with @Page.IsPost, @Page.Form[]",
        "Bootstrap 5 and HTMX integration",
        "Session management (@Page.Session[])",
        "Authentication and authorization",
        "Multi-tenancy support",
        "Enterprise security features",
        "Rapid CRUD development"
    };
    
    // Technology stack
    var techStack = new Dictionary<string, string> {
        {"Language", "Go 1.25+"},
        {"Database", "PostgreSQL 17+"},
        {"Frontend", "Bootstrap 5 + HTMX"},
        {"Security", "CSRF, Rate Limiting, Sessions"},
        {"Deployment", "Docker, Systemd"}
    };
    
    // Demo data
    var isPost = Page.IsPost;
    var name = Page.Form["name"];
    var email = Page.Form["email"];
    var message = Page.Form["message"];
    var formSubmitted = false;
    var validationErrors = new List<string>();
    
    // Handle form submission
    if (isPost)
    {
        // Validate
        if (string.IsNullOrEmpty(name))
        {
            validationErrors.Add("Name is required");
        }
        if (string.IsNullOrEmpty(email))
        {
            validationErrors.Add("Email is required");
        }
        else if (!email.Contains("@"))
        {
            validationErrors.Add("Please enter a valid email address");
        }
        
        if (validationErrors.Count == 0)
        {
            formSubmitted = true;
            // In production: Database.Execute("INSERT INTO contacts (name, email, message, created_at) VALUES (@0, @1, @2, NOW())", name, email, message);
        }
    }
}

@* Define the head section *@
@section head {
    <style>
        .feature-item {
            padding: 8px 12px;
            background: #f8f9fa;
            border-radius: 6px;
            transition: all 0.3s;
            margin-bottom: 5px;
        }
        .feature-item:hover {
            background: #e9ecef;
            transform: translateX(5px);
        }
        .tech-badge {
            display: inline-block;
            padding: 8px 16px;
            background: #667eea;
            color: white;
            border-radius: 20px;
            font-weight: bold;
            text-align: center;
            width: 100%;
        }
        .stat-box {
            padding: 15px;
            background: #f8f9fa;
            border-radius: 10px;
            border: 1px solid #e9ecef;
            text-align: center;
        }
        .stat-box h3 {
            margin: 0;
            color: #667eea;
            font-size: 2em;
        }
        pre {
            border-radius: 8px;
            font-size: 0.85em;
            max-height: 300px;
            overflow: auto;
        }
        pre code {
            color: #e9ecef;
        }
        .code-block {
            background: #1e1e1e;
            color: #d4d4d4;
            padding: 15px;
            border-radius: 8px;
            font-family: 'Consolas', 'Monaco', monospace;
            font-size: 0.85em;
            overflow: auto;
            max-height: 250px;
        }
        .code-block .keyword { color: #569cd6; }
        .code-block .string { color: #ce9178; }
        .code-block .comment { color: #6a9955; }
        .code-block .function { color: #dcdcaa; }
        .code-block .variable { color: #9cdcfe; }
    </style>
}

@* Define the main content - this goes into @RenderBody() in the layout *@
<div class="container">
    <div class="row">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item active">About</li>
                </ol>
            </nav>
        </div>
    </div>
    
    <div class="row">
        <!-- Main Content -->
        <div class="col-md-8">
            <!-- Framework Info -->
            <div class="card mb-4">
                <div class="card-header">
                    <h3><i class="bi bi-info-circle"></i> About @frameworkName</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <strong>Version:</strong> @version | 
                        <strong>Build:</strong> @buildDate | 
                        <strong>Status:</strong> <span class="badge bg-success">Production Ready</span>
                    </div>
                    
                    <p class="lead">@description</p>
                    
                    <p>
                        Mamba Framework is designed specifically for building enterprise business applications 
                        such as Payroll, HR, CRM, Accounting, Inventory, POS Administration, ERP, Hospital, and School systems.
                        It prioritizes <strong>simplicity</strong>, <strong>productivity</strong>, and 
                        <strong>rapid CRUD development</strong> over flexibility.
                    </p>
                    
                    <h4 class="mt-4"><i class="bi bi-list-check"></i> Key Features</h4>
                    <div class="row mt-2">
                        @foreach(var feature in features)
                        {
                            <div class="col-md-6">
                                <div class="feature-item">
                                    <i class="bi bi-check-circle-fill text-success"></i>
                                    <span>@feature</span>
                                </div>
                            </div>
                        }
                    </div>
                    
                    <h4 class="mt-4"><i class="bi bi-stack"></i> Technology Stack</h4>
                    <div class="row mt-2">
                        @foreach(var tech in techStack)
                        {
                            <div class="col-md-6 mb-2">
                                <div class="d-flex justify-content-between align-items-center">
                                    <strong>@tech.Key:</strong>
                                    <span class="badge bg-primary">@tech.Value</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
            
            <!-- WebMatrix Syntax Demo -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5><i class="bi bi-code-square"></i> WebMatrix Syntax Demo</h5>
                </div>
                <div class="card-body">
                    <h6>This page uses WebMatrix-style syntax:</h6>
                    
                    <div class="code-block">
                        <span class="comment">// WebMatrix @{} code block at the top of the page</span>
                        <span class="keyword">@</span>{<br>
                        &nbsp;&nbsp;&nbsp;&nbsp;<span class="keyword">var</span> <span class="variable">title</span> = <span class="string">"About"</span>;<br>
                        &nbsp;&nbsp;&nbsp;&nbsp;<span class="keyword">var</span> <span class="variable">features</span> = <span class="keyword">new</span> <span class="function">List</span>&lt;<span class="keyword">string</span>&gt; { ... };<br>
                        &nbsp;&nbsp;&nbsp;&nbsp;<span class="keyword">var</span> <span class="variable">isPost</span> = <span class="variable">Page</span>.<span class="function">IsPost</span>;<br>
                        &nbsp;&nbsp;&nbsp;&nbsp;<span class="keyword">var</span> <span class="variable">name</span> = <span class="variable">Page</span>.<span class="function">Form</span>[<span class="string">"name"</span>];<br>
                        }<br><br>
                        
                        <span class="comment">// @RenderBody() - where page content goes</span>
                        <span class="keyword">@</span><span class="function">RenderBody</span>()<br><br>
                        
                        <span class="comment">// @RenderSection for scripts</span>
                        <span class="keyword">@</span><span class="function">RenderSection</span>(<span class="string">"scripts"</span>, <span class="keyword">false</span>)<br><br>
                        
                        <span class="comment">// @if statement</span>
                        <span class="keyword">@if</span> (<span class="variable">isPost</span>) {<br>
                        &nbsp;&nbsp;&nbsp;&nbsp;<span class="comment">// Handle form submission</span><br>
                        &nbsp;&nbsp;&nbsp;&nbsp;<span class="keyword">@:</span>&lt;p&gt;Form was posted!&lt;/p&gt;<br>
                        }<br><br>
                        
                        <span class="comment">// @foreach loop</span>
                        <span class="keyword">@foreach</span>(<span class="keyword">var</span> <span class="variable">feature</span> <span class="keyword">in</span> <span class="variable">features</span>) {<br>
                        &nbsp;&nbsp;&nbsp;&nbsp;&lt;div&gt;<span class="keyword">@feature</span>&lt;/div&gt;<br>
                        }
                    </div>
                    
                    <div class="alert alert-success mt-3">
                        <i class="bi bi-check-circle"></i> 
                        <strong>This page is rendered using the WebMatrix engine!</strong> 
                        All the code above is executed server-side before the page is sent to the browser.
                    </div>
                    
                    <div class="row mt-3">
                        <div class="col-md-4">
                            <div class="stat-box">
                                <h3>@DateTime.Now.ToString("HH:mm:ss")</h3>
                                <p class="text-muted">Current Time <br><small>(@DateTime.Now.ToString("yyyy-MM-dd"))</small></p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="stat-box">
                                <h3>@(isPost ? "POST" : "GET")</h3>
                                <p class="text-muted">Request Method</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="stat-box">
                                <h3>@features.Count</h3>
                                <p class="text-muted">Features</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Sidebar Content -->
        <div class="col-md-4">
            <!-- Contact Form Demo -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5><i class="bi bi-envelope"></i> Contact Us</h5>
                </div>
                <div class="card-body">
                    @if (formSubmitted)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle"></i> 
                            Thank you <strong>@name</strong>! Your message has been sent.
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    else if (validationErrors.Count > 0)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle"></i>
                            <strong>Please fix the following errors:</strong>
                            <ul class="mb-0 mt-1">
                                @foreach(var error in validationErrors)
                                {
                                    <li>@error</li>
                                }
                            </ul>
                        </div>
                    }
                    
                    <form method="POST">
                        @Html.AntiForgeryToken()
                        
                        <div class="mb-3">
                            <label class="form-label">Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control @(isPost && string.IsNullOrEmpty(name) ? "is-invalid" : "")" 
                                   name="name" placeholder="Your name" value="@name">
                            @if (isPost && string.IsNullOrEmpty(name))
                            {
                                <div class="invalid-feedback">Name is required</div>
                            }
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Email <span class="text-danger">*</span></label>
                            <input type="email" class="form-control @(isPost && (string.IsNullOrEmpty(email) || !email.Contains("@")) ? "is-invalid" : "")" 
                                   name="email" placeholder="Your email" value="@email">
                            @if (isPost && string.IsNullOrEmpty(email))
                            {
                                <div class="invalid-feedback">Email is required</div>
                            }
                            else if (isPost && !email.Contains("@"))
                            {
                                <div class="invalid-feedback">Please enter a valid email</div>
                            }
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Message</label>
                            <textarea class="form-control" name="message" rows="3" placeholder="Your message">@message</textarea>
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-send"></i> Send Message
                        </button>
                        
                        <div class="mt-2 text-center">
                            <small class="text-muted">* Required fields</small>
                        </div>
                    </form>
                </div>
            </div>
            
            <!-- Session Demo -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5><i class="bi bi-clock-history"></i> Session Demo</h5>
                </div>
                <div class="card-body">
                    @{
                        var visitCount = 0;
                        if (Page.Session.ContainsKey("about_visit_count"))
                        {
                            visitCount = (int)Page.Session["about_visit_count"];
                        }
                        visitCount++;
                        Page.Session["about_visit_count"] = visitCount;
                    }
                    <div class="text-center">
                        <h1 class="display-4 text-primary">@visitCount</h1>
                        <p class="text-muted">Page visits this session</p>
                        <small class="text-muted">
                            <i class="bi bi-database"></i> Session data stored in @Page.Session
                        </small>
                    </div>
                    
                    <div class="mt-2 text-center">
                        <button class="btn btn-sm btn-outline-primary" 
                                onclick="location.reload()">
                            <i class="bi bi-arrow-clockwise"></i> Refresh to increment
                        </button>
                    </div>
                </div>
            </div>
            
            <!-- Database Demo -->
            <div class="card">
                <div class="card-header">
                    <h5><i class="bi bi-database"></i> Database Demo</h5>
                </div>
                <div class="card-body">
                    @{
                        var db = Database;
                        var employees = db.Query("SELECT * FROM employees ORDER BY name");
                    }
                    <div class="text-center mb-2">
                        <span class="badge bg-primary">@employees.Count Employees</span>
                    </div>
                    <div class="list-group">
                        @foreach(var emp in employees)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <span>
                                    <i class="bi bi-person"></i> @emp.name
                                </span>
                                <span class="badge bg-secondary">@emp.department</span>
                            </div>
                        }
                    </div>
                    <div class="mt-2">
                        <small class="text-muted">
                            <i class="bi bi-info-circle"></i> Data from @Database.Query()
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* Define the scripts section - this goes into @RenderSection("scripts") in the layout *@
@section scripts {
    <script>
        console.log('========================================');
        console.log('About Page Loaded');
        console.log('========================================');
        console.log('Time: @DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")');
        console.log('Request Method: @(isPost ? "POST" : "GET")');
        console.log('Session Visit Count: @(Page.Session.ContainsKey("about_visit_count") ? Page.Session["about_visit_count"] : 0)');
        console.log('========================================');
        
        // Auto-dismiss alerts after 5 seconds
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.alert').forEach(function(alert) {
                setTimeout(function() {
                    alert.classList.remove('show');
                    setTimeout(function() { alert.remove(); }, 300);
                }, 5000);
            });
        });
    </script>
}
