@{
    // WebMatrix @{} code block
    var title = "Create Employee";
    var db = Database;
    var isPost = Page.IsPost;
    
    // Form values
    var firstName = Page.Form["firstName"];
    var lastName = Page.Form["lastName"];
    var email = Page.Form["email"];
    var department = Page.Form["department"];
    var status = Page.Form["status"];
    
    // Validation
    var errors = new Dictionary<string, string>();
    
    if (isPost)
    {
        if (string.IsNullOrEmpty(firstName))
            errors["firstName"] = "First name is required";
        if (string.IsNullOrEmpty(lastName))
            errors["lastName"] = "Last name is required";
        if (string.IsNullOrEmpty(email))
            errors["email"] = "Email is required";
        
        if (errors.Count == 0)
        {
            // Save to database
            var id = db.Execute(
                "INSERT INTO employees (first_name, last_name, email, department, status, created_at) VALUES (@0, @1, @2, @3, @4, NOW())",
                firstName, lastName, email, department, status
            );
            <script>window.location.href = '/employees?success=created';</script>
        }
    }
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card">
                <div class="card-header">
                    <h3><i class="bi bi-person-plus"></i> Create Employee</h3>
                </div>
                <div class="card-body">
                    @if (isPost && errors.Count > 0)
                    {
                        <div class="alert alert-danger">
                            <h5>Please fix the following errors:</h5>
                            <ul>
                                @foreach(var error in errors)
                                {
                                    <li>@error.Value</li>
                                }
                            </ul>
                        </div>
                    }
                    
                    <form method="POST">
                        @Html.AntiForgeryToken()
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">First Name</label>
                                    <input type="text" class="form-control @(errors.ContainsKey("firstName") ? "is-invalid" : "")" 
                                           name="firstName" value="@firstName">
                                    @if (errors.ContainsKey("firstName"))
                                    {
                                        <div class="invalid-feedback">@errors["firstName"]</div>
                                    }
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label">Last Name</label>
                                    <input type="text" class="form-control @(errors.ContainsKey("lastName") ? "is-invalid" : "")" 
                                           name="lastName" value="@lastName">
                                    @if (errors.ContainsKey("lastName"))
                                    {
                                        <div class="invalid-feedback">@errors["lastName"]</div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control @(errors.ContainsKey("email") ? "is-invalid" : "")" 
                                   name="email" value="@email">
                            @if (errors.ContainsKey("email"))
                            {
                                <div class="invalid-feedback">@errors["email"]</div>
                            }
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Department</label>
                            <select class="form-select" name="department">
                                <option value="">Select Department</option>
                                <option value="Engineering" @(department == "Engineering" ? "selected" : "")>Engineering</option>
                                <option value="Marketing" @(department == "Marketing" ? "selected" : "")>Marketing</option>
                                <option value="Sales" @(department == "Sales" ? "selected" : "")>Sales</option>
                                <option value="HR" @(department == "HR" ? "selected" : "")>HR</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Status</label>
                            <select class="form-select" name="status">
                                <option value="active" @(status == "active" ? "selected" : "")>Active</option>
                                <option value="inactive" @(status == "inactive" ? "selected" : "")>Inactive</option>
                                <option value="onleave" @(status == "onleave" ? "selected" : "")>On Leave</option>
                            </select>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="/employees" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Create Employee
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
