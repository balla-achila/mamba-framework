@{
    // WebMatrix @{} code block
    var title = "Employees";
    var db = Database;
    var employees = db.Query("SELECT * FROM employees ORDER BY name");
    var total = employees.Count;
    var isPost = Page.IsPost;
}

@if (isPost)
{
    var action = Page.Form["action"];
    if (action == "delete")
    {
        var id = Page.Form["id"];
        db.Execute("DELETE FROM employees WHERE id = @0", id);
        <script>window.location.href = '/employees';</script>
    }
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2><i class="bi bi-people"></i> Employees</h2>
        <p class="text-muted">Manage your workforce - @total total employees</p>
    </div>
    <div>
        <a href="/employees/create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Employee
        </a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Department</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var employee in employees)
                    {
                        <tr>
                            <td>@employee.id</td>
                            <td>@employee.name</td>
                            <td>@employee.email</td>
                            <td>@employee.department</td>
                            <td>
                                @if (employee.status == "active")
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else if (employee.status == "inactive")
                                {
                                    <span class="badge bg-danger">Inactive</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">On Leave</span>
                                }
                            </td>
                            <td>
                                <a href="/employees/view/@employee.id" class="btn btn-sm btn-info">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="/employees/edit/@employee.id" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="POST" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="action" value="delete">
                                    <input type="hidden" name="id" value="@employee.id">
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this employee?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section scripts {
    <script>
        // HTMX for search
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Employees page loaded');
        });
    </script>
}
