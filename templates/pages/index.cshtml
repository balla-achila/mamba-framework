@{
    // WebMatrix @{} code block at the top
    var title = "Dashboard";
    var db = Database;
    var employees = db.Query("SELECT * FROM employees WHERE active = true ORDER BY name");
    var totalEmployees = employees.Count;
    var departments = db.Query("SELECT * FROM departments ORDER BY name");
    var recentActivities = db.Query("SELECT * FROM activities ORDER BY created_at DESC LIMIT 5");
    var isPost = Page.IsPost;
}

@if (isPost)
{
    // Handle form submission
    var action = Page.Form["action"];
    if (action == "refresh")
    {
        // Refresh data
    }
}

<div class="row">
    <div class="col-md-3 mb-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title text-primary">
                    <i class="bi bi-people fs-1"></i>
                </h5>
                <h3>@totalEmployees</h3>
                <p class="text-muted">Total Employees</p>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title text-success">
                    <i class="bi bi-building fs-1"></i>
                </h5>
                <h3>@departments.Count</h3>
                <p class="text-muted">Departments</p>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title text-info">
                    <i class="bi bi-person-check fs-1"></i>
                </h5>
                <h3>89%</h3>
                <p class="text-muted">Attendance Rate</p>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title text-warning">
                    <i class="bi bi-graph-up fs-1"></i>
                </h5>
                <h3>$45K</h3>
                <p class="text-muted">Revenue</p>
            </div>
        </div>
    </div>
</div>

<!-- Recent Activity -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-clock-history"></i> Recent Activity</h5>
        <form method="POST" style="display:inline;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="action" value="refresh">
            <button type="submit" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-arrow-clockwise"></i> Refresh
            </button>
        </form>
    </div>
    <div class="card-body" id="activity-list">
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Action</th>
                        <th>Time</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var activity in recentActivities)
                    {
                        <tr>
                            <td>@activity.user</td>
                            <td>@activity.action</td>
                            <td>@activity.created_at</td>
                            <td><span class="badge bg-@activity.status_color">@activity.status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section scripts {
    <script>
        console.log('Dashboard loaded');
    </script>
}
