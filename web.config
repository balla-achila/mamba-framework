<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Database Connection Strings -->
    <connectionStrings>
        <add name="DefaultConnection" 
             connectionString="Data Source=localhost;Initial Catalog=MambaDB;Integrated Security=True;Pooling=True;Max Pool Size=100;Min Pool Size=10;" 
             providerName="System.Data.SqlClient" />
        <add name="MambaDB" 
             connectionString="Server=localhost;Database=MambaDB;User Id=mamba;Password=mamba_password;Pooling=True;Max Pool Size=100;Min Pool Size=10;" 
             providerName="System.Data.SqlClient" />
        <add name="PostgreSQL" 
             connectionString="Host=localhost;Port=5432;Database=MambaDB;Username=mamba;Password=mamba_password;Pooling=True;MaxPoolSize=100;MinPoolSize=10;" 
             providerName="Npgsql" />
    </connectionStrings>

    <!-- Application Settings -->
    <appSettings>
        <add key="SiteName" value="Mamba Framework" />
        <add key="Version" value="1.0.0" />
        <add key="Environment" value="Development" />
        <add key="EnableDebug" value="true" />
        <add key="DefaultLanguage" value="en-US" />
        <add key="TimeZone" value="UTC" />
        <add key="DateFormat" value="yyyy-MM-dd" />
        <add key="DateTimeFormat" value="yyyy-MM-dd HH:mm:ss" />
        <add key="CompanyName" value="Mamba Technologies" />
        <add key="SupportEmail" value="support@mamba-framework.com" />
        <add key="MaxUploadSize" value="10485760" /> <!-- 10MB -->
        <add key="EnableLogging" value="true" />
        <add key="LogLevel" value="Info" />
        <add key="PageSize" value="20" />
        <add key="EnableCaching" value="true" />
        <add key="CacheDuration" value="3600" />
    </appSettings>

    <!-- Custom Errors -->
    <customErrors mode="RemoteOnly" defaultRedirect="/error">
        <error statusCode="404" redirect="/not-found" />
        <error statusCode="500" redirect="/error" />
        <error statusCode="403" redirect="/forbidden" />
    </customErrors>

    <!-- Authentication -->
    <authentication mode="Forms">
        <forms name="MambaAuth" 
               loginUrl="/login" 
               defaultUrl="/" 
               protection="All" 
               timeout="30" 
               path="/" 
               requireSSL="false" 
               slidingExpiration="true" 
               enableCrossAppRedirects="false" 
               cookieless="UseDeviceProfile" 
               domain="">
            <credentials passwordFormat="SHA1">
                <user name="admin" password="admin123" />
                <user name="user" password="user123" />
            </credentials>
        </forms>
    </authentication>

    <!-- Authorization -->
    <authorization>
        <allow users="admin,user" />
        <deny users="?" /> <!-- Deny anonymous users -->
    </authorization>

    <!-- Session State -->
    <sessionState mode="InProc" 
                  cookieless="false" 
                  timeout="20" 
                  stateConnectionString="tcpip=127.0.0.1:42424" 
                  sqlConnectionString="data source=127.0.0.1;Trusted_Connection=yes" 
                  regenerateExpiredSessionId="false" 
                  sameSite="Lax">
        <providers>
            <add name="InProc" type="System.Web.SessionState.InProcSessionStateStore" />
        </providers>
    </sessionState>

    <!-- Security Configuration -->
    <security>
        <csrf enabled="true" tokenExpiration="3600" />
        <rateLimiting enabled="true" maxRequests="100" timeWindow="60" />
        <cors enabled="false">
            <origins>
                <add origin="*" />
            </origins>
        </cors>
        <hsts enabled="true" maxAge="31536000" includeSubDomains="true" preload="true" />
        <xssProtection enabled="true" mode="block" />
        <frameOptions enabled="true" value="SAMEORIGIN" />
        <contentTypeOptions enabled="true" value="nosniff" />
    </security>

    <!-- Caching Configuration -->
    <caching>
        <enabled>true</enabled>
        <defaultDuration>3600</defaultDuration>
        <enableCompression>true</enableCompression>
        <cacheDirectory>/tmp/mamba_cache</cacheDirectory>
    </caching>

    <!-- Logging Configuration -->
    <logging>
        <enabled>true</enabled>
        <level>Info</level>
        <file>/logs/mamba.log</file>
        <maxSize>10485760</maxSize> <!-- 10MB -->
        <maxBackups>5</maxBackups>
        <maxAge>30</maxAge> <!-- Days -->
        <compress>true</compress>
    </logging>

    <!-- File Upload Configuration -->
    <upload>
        <maxSize>10485760</maxSize> <!-- 10MB -->
        <allowedTypes>
            <add type="image/jpeg" />
            <add type="image/png" />
            <add type="image/gif" />
            <add type="image/webp" />
            <add type="application/pdf" />
            <add type="application/msword" />
            <add type="application/vnd.openxmlformats-officedocument.wordprocessingml.document" />
            <add type="application/vnd.ms-excel" />
            <add type="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" />
            <add type="text/csv" />
            <add type="application/zip" />
        </allowedTypes>
        <tempDirectory>/tmp/mamba_uploads</tempDirectory>
        <chunkSize>1048576</chunkSize> <!-- 1MB -->
    </upload>

    <!-- Tenant Configuration -->
    <tenant>
        <enabled>true</enabled>
        <defaultTenant>default</defaultTenant>
        <header>X-Tenant-ID</header>
        <param>tenant</param>
        <mode>Header</mode> <!-- Header, QueryString, Subdomain -->
    </tenant>

    <!-- Email Configuration -->
    <email>
        <smtpServer>smtp.gmail.com</smtpServer>
        <smtpPort>587</smtpPort>
        <smtpUsername>noreply@mamba-framework.com</smtpUsername>
        <smtpPassword>password</smtpPassword>
        <enableSSL>true</enableSSL>
        <fromAddress>noreply@mamba-framework.com</fromAddress>
        <fromName>Mamba Framework</fromName>
    </email>

    <!-- API Configuration -->
    <api>
        <enabled>true</enabled>
        <version>v1</version>
        <rateLimit>100</rateLimit>
        <rateLimitWindow>60</rateLimitWindow> <!-- Seconds -->
        <authentication>Bearer</authentication>
        <corsEnabled>true</corsEnabled>
        <corsOrigins>
            <add origin="*" />
        </corsOrigins>
    </api>

    <!-- Database Configuration -->
    <database>
        <defaultProvider>PostgreSQL</defaultProvider>
        <autoMigrate>true</autoMigrate>
        <seedData>true</seedData>
        <commandTimeout>30</commandTimeout> <!-- Seconds -->
        <connectionRetryCount>3</connectionRetryCount>
        <connectionRetryDelay>1000</connectionRetryDelay> <!-- Milliseconds -->
    </database>

    <!-- Health Checks -->
    <healthChecks>
        <enabled>true</enabled>
        <checkDatabase>true</checkDatabase>
        <checkCache>true</checkCache>
        <checkDiskSpace>true</checkDiskSpace>
        <checkMemory>true</checkMemory>
        <checkInterval>60</checkInterval> <!-- Seconds -->
    </healthChecks>

    <!-- System.Web Compatible Settings -->
    <system.web>
        <compilation debug="true" targetFramework="4.8" />
        <httpRuntime targetFramework="4.8" maxRequestLength="10240" executionTimeout="90" />
        <pages controlRenderingCompatibilityVersion="4.5" />
        <machineKey validationKey="auto" decryptionKey="auto" validation="SHA1" decryption="Auto" />
    </system.web>

    <!-- Url Rewriting -->
    <urlRewriting>
        <enabled>true</enabled>
        <rules>
            <rule name="DefaultPage" pattern="^$" substitution="/index.gshtml" />
            <rule name="AboutPage" pattern="^about$" substitution="/about.gshtml" />
            <rule name="Employees" pattern="^employees$" substitution="/employees.gshtml" />
            <rule name="EmployeeCreate" pattern="^employees/create$" substitution="/employee-create.gshtml" />
            <rule name="EmployeeEdit" pattern="^employees/edit/(\d+)$" substitution="/employee-edit.gshtml?id=$1" />
            <rule name="EmployeeView" pattern="^employees/view/(\d+)$" substitution="/employee-view.gshtml?id=$1" />
        </rules>
    </urlRewriting>
</configuration>
